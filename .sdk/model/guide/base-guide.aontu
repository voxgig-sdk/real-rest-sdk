# Guide

guide: {
  metrics: count: entity: 1
  metrics: count: path: 3
  metrics: count: method: 7

  entity: object: {
    path: "/objects": {
      op: create: method: *POST
      op: list: method: *GET
    }
    path: "/objects/{id}": {
      op: load: method: *GET
      op: patch: method: *PATCH
      op: remove: method: *DELETE
      op: update: method: *PUT
    }
    path: "/objects?id={ids}": {
      op: list: method: *GET
    }
  }

}