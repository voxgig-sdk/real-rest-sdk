# BasicObjectFlow

main: kit: flow: BasicObjectFlow:
{
  entity: "object",
  kind: "basic",
  name: "BasicObjectFlow",
  step: [
    {
      input: {
        ref: "object_ref01"
      }

      op: "create"
    }

    {
      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "object_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "object_ref01",
        srcdatavar: "object_ref01_data",
        suffix: "_up0",
        textfield: "name"
      }

      op: "update",
      spec: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-object_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "object_ref01",
        srcdatavar: "object_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "object01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-object_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "object_ref01",
        suffix: "_rm0"
      }

      match: {
        id: "object01"
      }

      op: "remove"
    }

    {
      input: {
        suffix: "_rt0"
      }

      op: "list",
      valid: [
        {
          apply: "ItemNotExists",
          def: {
            ref: "object_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicObjectFlow"
}